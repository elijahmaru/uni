      "source": [
        "x = 2\n",
        "y = 50\n",
        "z = []\n",
        "for i in range(x, y + 1):\n",
        "    f = True\n",
        "    for j in range(2, i):\n",
        "        if i % j == 0:\n",
        "            f = False\n",
        "            break\n",
        "    if f:\n",
        "        z.append(i)\n",
        "print(z)"
      ]
    }
  ]
